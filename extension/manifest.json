{
  "manifest_version": 3,
  "name": "Fake Crypto Claim Detector",
  "version": "1.0",
  "description": "Bôi đen nội dung (claim) để kiểm tra xem đúng hay sai.",
  "permissions": [
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
